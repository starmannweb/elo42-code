# Application
APP_NAME="Elo 42 Platform"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=elo42_platform
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_NAME=elo42_session
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_PATH=storage/sessions

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=contato@elo42.com.br
MAIL_FROM_NAME="Elo 42"

# Payment Gateway (Stripe, PagSeguro, Asaas, etc.)
PAYMENT_PROVIDER=stripe
PAYMENT_API_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_SANDBOX=true

# WhatsApp (Twilio, Z-API, Evolution API, etc.)
WHATSAPP_PROVIDER=twilio
WHATSAPP_API_KEY=
WHATSAPP_API_SECRET=
WHATSAPP_FROM_NUMBER=
WHATSAPP_WEBHOOK_URL=

# PDF Generation
PDF_DRIVER=dompdf
