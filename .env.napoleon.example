# Application
APP_NAME="Elo 42 Platform"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://SEU_DOMINIO.com.br
APP_TIMEZONE=America/Sao_Paulo
AUTH_ALLOW_OFFLINE=false
ASSET_VERSION=

# Database - preencher com os dados criados no Napoleon/DirectAdmin
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=USUARIO_nome_do_banco
DB_USERNAME=USUARIO_usuario_do_banco
DB_PASSWORD=SENHA_FORTE_AQUI

# Session
SESSION_NAME=elo42_session
SESSION_LIFETIME=240
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_PATH=storage/sessions

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=suporte@SEU_DOMINIO.com.br
MAIL_FROM_NAME="Elo 42"

# Payment Gateway
PAYMENT_PROVIDER=stripe
PAYMENT_API_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_SANDBOX=false

# WhatsApp
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
WHATSAPP_API_SECRET=
WHATSAPP_FROM_NUMBER=
WHATSAPP_WEBHOOK_URL=

# PDF Generation
PDF_DRIVER=dompdf
